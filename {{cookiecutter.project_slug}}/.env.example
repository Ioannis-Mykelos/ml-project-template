"""Environment variables for the project"""

# Environment variables for the project
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key
DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=UTC
LANGUAGE_CODE=en-us
USE_I18N=True
USE_L10N=True
USE_TZ=True

####### Data path settings #######
##################################
DATA_PATH_PREPROCESSING=/path/to/preprocessing/data
DATA_PATH_TRAINING=/path/to/training/data
DATA_PATH_SCORING=/path/to/scoring/data
DATA_PATH_POSTPROCESSING=/path/to/postprocessing/data
DATA_PATH_PRODUCTION=/path/to/production/data
DATA_PATH_MONITORING=/path/to/monitoring/data
